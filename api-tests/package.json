{
  "name": "sefaria-api-tests",
  "version": "1.0.0",
  "description": "Comprehensive API tests for Sefaria",
  "scripts": {
    "test": "playwright test",
    "test:prod": "API_BASE_URL=https://www.sefaria.org playwright test",
